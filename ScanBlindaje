import requests
import time
import aiohttp
import asyncio

start_time = time.time()
class Shipment:
    def __init__(self,):
        self.listado_shipments = []
        self.listado_shipments_sin_tag = []
        
    def LeerArchivo(self):#Leemos el archivo y lo agregamos a una lista
         with open('Blindaje//input.txt', 'r') as archivo1:
            for i in archivo1:
                self.listado_shipments.append(i.split())
                
    
    async def ObtenerTags(self):
        
        for shipment in self.listado_shipments:
            for x in shipment:
                
                async with aiohttp.ClientSession() as session:
                    async with session.get(f"http://internal-api.mercadolibre.com//shipments/{x}?caller.scopes=admin") as resp:
                    
                        contenido = await resp.json()
                        tag=  contenido["tags"]
                        if "carrier_contingency" in tag:
                                with open('Blindaje\\tags.txt', 'a') as archivo:
                                    archivo.write(f"{x} \n")
                        else:
                            self.listado_shipments_sin_tag.append(x)
                            with open ("Blindaje\\No_tiene_blindaje.txt","w") as ArchivoSinTag:
                                for self.Shipment_sin_tag in self.listado_shipments_sin_tag:
                                    ArchivoSinTag.write(self.Shipment_sin_tag + "\n")

        print("---%s segundos----"%(time.time() - start_time))
                    
                

                
    
        



if __name__ =="__main__":
    resultado = Shipment()
    resultado.LeerArchivo()
    asyncio.run(resultado.ObtenerTags())



























